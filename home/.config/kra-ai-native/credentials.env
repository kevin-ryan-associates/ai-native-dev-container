# 1Password secret references for the kra-ai-native container.
# Each line: ENV_VAR=op://vault/item/field
# Create matching items in a 1Password vault (default: DevContainer).
# Run `creds` to resolve these into your shell environment.

# Git commit identity
GIT_AUTHOR_NAME=op://DevContainer/git/username
GIT_AUTHOR_EMAIL=op://DevContainer/git/email
GIT_COMMITTER_NAME=op://DevContainer/git/username
GIT_COMMITTER_EMAIL=op://DevContainer/git/email

# GitHub personal access token (scopes: repo, read:org, workflow)
GH_TOKEN=op://DevContainer/github/token

# GitLab personal access token (scopes: api, write_repository)
GITLAB_TOKEN=op://DevContainer/gitlab/token

# OpenCode Zen API key (from https://opencode.ai/auth)
OPENCODE_API_KEY=op://DevContainer/opencode-zen/api-key
