#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME=${AIDEV_IMAGE:-aidev:latest}
AIDEV_HOME=${AIDEV_HOME:-$HOME/.local/share/aidev}

usage() {
  cat <<EOF
Usage:
  aidev                     Launch zsh in current directory (default)
  aidev build               Build the image from $AIDEV_HOME
  aidev update              Rebuild the image with --pull (refresh bases)
  aidev shell               Launch zsh in current directory
  aidev [--build] <tool> [args...]

Examples:
  aidev
  aidev nvim .
  aidev shell
  aidev --build nvim .
EOF
}

build_image() {
  if [ ! -f "$AIDEV_HOME/Dockerfile" ]; then
    echo "Missing Dockerfile in $AIDEV_HOME. Run install.sh from the repo first." >&2
    exit 1
  fi
  docker build "$@" -t "$IMAGE_NAME" "$AIDEV_HOME"
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  build)
    build_image
    exit 0
    ;;
  update)
    build_image --pull
    exit 0
    ;;
  shell)
    shift
    set -- zsh "$@"
    ;;
  --build)
    shift
    build_image
    ;;
esac

tool=${1:-zsh}
shift || true

if ! docker image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
  build_image
fi

docker_args=(
  --rm
  -e HOST_UID="$(id -u)"
  -e HOST_GID="$(id -g)"
  -v "$PWD:/workspace"
  -w /workspace
)

if [ -t 0 ] && [ -t 1 ]; then
  docker_args+=( -it )
fi

exec docker run "${docker_args[@]}" "$IMAGE_NAME" "$tool" "$@"
