#!/usr/bin/env bash
set -euo pipefail

command -v docker >/dev/null 2>&1 || { echo "kra-ai-native: docker not found on PATH" >&2; exit 1; }

IMAGE_NAME=${KRA_AI_NATIVE_IMAGE:-kra-ai-native:latest}
KRA_AI_NATIVE_HOME=${KRA_AI_NATIVE_HOME:-$HOME/.local/share/kra-ai-native}

usage() {
  cat <<EOF
Usage:
  kra-ai-native            Launch zsh in current directory (default)
  kra-ai-native build      Build the image from $KRA_AI_NATIVE_HOME
  kra-ai-native update     Rebuild the image with --pull (refresh bases)
  kra-ai-native shell      Launch zsh in current directory
  kra-ai-native [--build] [--port SPEC|--port-range RANGE] <tool> [args...]

Port forwarding:
  -p, --port SPEC          Publish a port (e.g. 3000, 8080:8080,
                           127.0.0.1:5432:5432). Repeatable; additive.
      --port-range RANGE   Override the config/env/default forwarded range
                           (e.g. 3000-3999).

Project config:
  A .ai-native file (key=value) in the project root or any parent directory
  can set project-local defaults. Walks up from the current directory.
    port_range=RANGE       Forward a port range (e.g. 3000-3005).
    ports=SPEC1,SPEC2      Comma-separated explicit ports.

By default no ports are published unless a .ai-native file, env var, or
CLI flag configures them. Disable the automatic range with:
  KRA_AI_NATIVE_NO_PORTS=1
  KRA_AI_NATIVE_PORT_RANGE=none
Add explicit ports with:
  KRA_AI_NATIVE_PORTS=3000,8080:8080

The image is built lazily on first run, then reused. After upgrading the
package (npm update -g / reinstall), run 'kra-ai-native update' to rebuild
the image against the new files -- an existing kra-ai-native:latest is kept
otherwise.

Examples:
  kra-ai-native
  kra-ai-native nvim .
  kra-ai-native shell
  kra-ai-native --build nvim .
  kra-ai-native -p 5000 nvim .
  KRA_AI_NATIVE_NO_PORTS=1 kra-ai-native
EOF
}

build_image() {
  if [ ! -f "$KRA_AI_NATIVE_HOME/Dockerfile" ]; then
    echo "Missing Dockerfile in $KRA_AI_NATIVE_HOME. Run install.sh from the repo first." >&2
    exit 1
  fi
  docker build "$@" -t "$IMAGE_NAME" "$KRA_AI_NATIVE_HOME"
}

detect_host_tz() {
  if [ -n "${TZ:-}" ]; then printf '%s' "$TZ"; return 0; fi
  local link
  link=$(readlink /etc/localtime 2>/dev/null || true)
  case "$link" in
    */zoneinfo/*) printf '%s' "${link##*/zoneinfo/}"; return 0;;
  esac
  [ -f /etc/timezone ] && { cat /etc/timezone; return 0; }
  return 1
}

# Load project-local .ai-native config (key=value) by walking up from $PWD.
# Supports: port_range, ports.
load_config() {
  local dir="$PWD"
  while [ -n "$dir" ] && [ "$dir" != "/" ]; do
    if [ -r "$dir/.ai-native" ]; then
      while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
          ''|\#*) continue ;;
        esac
        local key val
        key="${line%%=*}"
        val="${line#*=}"
        [ "$key" = "$line" ] && continue
        # trim leading/trailing whitespace
        key="${key#"${key%%[![:space:]]*}"}"
        key="${key%"${key##*[![:space:]]}"}"
        val="${val#"${val%%[![:space:]]*}"}"
        val="${val%"${val##*[![:space:]]}"}"
        case "$key" in
          port_range) cfg_port_range="$val" ;;
          ports)      cfg_ports="$val" ;;
        esac
      done < "$dir/.ai-native"
      break
    fi
    dir="${dir%/*}"
  done
}

# Strip port-forwarding flags off the front of $@ before command dispatch,
# so e.g. "kra-ai-native -p 3000 nvim ." still selects `nvim` as the tool.
port_args=()
cli_range=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    --port|-p)
      [ "$#" -lt 2 ] && { echo "kra-ai-native: $1 requires a port spec" >&2; exit 2; }
      # A bare port (no ":") maps host:container at the same port, so
      # `kra-ai-native -p 5000` forwards host:5000 -> container:5000
      # rather than docker's default of a random host port.
      case "$2" in
        *:*) port_args+=( -p "$2" ) ;;
        *)   port_args+=( -p "$2:$2" ) ;;
      esac
      shift 2 ;;
    --port-range)
      [ "$#" -lt 2 ] && { echo "kra-ai-native: $1 requires a range spec" >&2; exit 2; }
      cli_range="$2"; shift 2 ;;
    --)
      shift; break ;;
    *)
      break ;;
  esac
done

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  build)
    build_image
    exit 0
    ;;
  update)
    build_image --pull
    exit 0
    ;;
  shell)
    shift
    set -- zsh "$@"
    ;;
  --build)
    shift
    build_image
    ;;
esac

tool=${1:-zsh}
shift || true

if ! docker image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
  build_image
fi

cfg_port_range=""
cfg_ports=""
load_config

docker_args=(
  --rm
  --privileged
  -e HOST_UID="$(id -u)"
  -e HOST_GID="$(id -g)"
  -v "$PWD:/workspace"
  -w /workspace
)

# Port forwarding to the host. By default no ports are published.
# Forwarding is opt-in via .ai-native config, env vars, or CLI flags.
# Override the range with --port-range or KRA_AI_NATIVE_PORT_RANGE;
# disable with KRA_AI_NATIVE_NO_PORTS=1 or KRA_AI_NATIVE_PORT_RANGE=none.
# Precedence: CLI > env > .ai-native config > default (none).
range="${KRA_AI_NATIVE_PORT_RANGE:-${cfg_port_range}}"
[ -n "$cli_range" ] && range="$cli_range"
if [ "${KRA_AI_NATIVE_NO_PORTS:-0}" != "1" ] && [ "$range" != "none" ] && [ -n "$range" ]; then
  docker_args+=( -p "${range}:${range}" )
fi

# Explicit comma-separated ports, e.g. KRA_AI_NATIVE_PORTS=3000,8080:8080.
# Specs without a ":" are expanded to PORT:PORT (0.0.0.0).
# Precedence: env > .ai-native config.
_ports_env_or_cfg="${KRA_AI_NATIVE_PORTS:-${cfg_ports}}"
if [ -n "$_ports_env_or_cfg" ]; then
  IFS=',' read -ra _ports <<< "$_ports_env_or_cfg"
  for _p in "${_ports[@]}"; do
    [ -z "$_p" ] && continue
    case "$_p" in
      *:*) port_args+=( -p "$_p" ) ;;
      *)   port_args+=( -p "$_p:$_p" ) ;;
    esac
  done
fi
if [ "${#port_args[@]}" -gt 0 ]; then
  docker_args+=( "${port_args[@]}" )
fi

host_tz=$(detect_host_tz || true)
if [ -n "$host_tz" ]; then
  docker_args+=( -e "TZ=$host_tz" )
fi

if [ -t 0 ] && [ -t 1 ]; then
  docker_args+=( -it )
fi

exec docker run "${docker_args[@]}" "$IMAGE_NAME" "$tool" "$@"
